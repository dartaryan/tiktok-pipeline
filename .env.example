# === API Keys ===
GROQ_API_KEY=gsk_your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here
GITHUB_TOKEN=ghp_your_token_here

# === GitHub Repo ===
GITHUB_REPO=your-username/tiktok-knowledge
GITHUB_BRANCH=main

# === GitHub Pages (optional, auto-derived from GITHUB_REPO) ===
# GITHUB_PAGES_URL=https://your-username.github.io/tiktok-knowledge/

# === Instagram Cookies (required for Instagram Reels) ===
# Export a Netscape-format cookies.txt from Firefox while logged into Instagram.
# YouTube and TikTok work without cookies.
# INSTAGRAM_COOKIES_FILE=cookies.txt

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === Optional: Restrict bot to your Telegram user ID ===
# Find your ID by messaging @userinfobot on Telegram
# ALLOWED_USER_IDS=123456789
